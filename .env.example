# In LOCALE con Prisma "prisma dev" puoi usare prisma+postgres://...
# Su VERCEL serve un Postgres in cloud (stesso schema): copia da Neon o Supabase.
# Esempio: postgresql://user:pass@ep-xxx.eu-west-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Stessi valori su Vercel (Production). Genera stringhe casuali lunghe (es. openssl rand -hex 32)
INGEST_SECRET=""
CRON_SECRET=""

# Password per /organizzatori (form web per annunci e date). Genera una stringa lunga e unica.
ADMIN_PASSWORD=""

# Opzionale: per scripts/post-asgm-ingest.mjs (URL deployment Vercel — vedi SITE.md)
# ASGM_BASE_URL=https://asgm-2acdwhouc-gpittons-projects.vercel.app

# Opzionale — ultimi post Facebook in home (oltre al plugin già integrato).
# Serve un token di pagina da Meta for Developers con permessi sulla pagina.
# FACEBOOK_PAGE_SLUG=micologia.sandonatese
# FACEBOOK_PAGE_ACCESS_TOKEN=

# Opzionale — logo in header (altrimenti, con token Facebook sopra, si usa la foto profilo della Pagina).
# SITE_LOGO_URL=https://...

# Coda schede automatiche: file data/species-queue.json (titoli voce Wikipedia IT).
# Cron Vercel: lunedì ~07:30 UTC → /api/cron/species-weekly (stesso CRON_SECRET).
